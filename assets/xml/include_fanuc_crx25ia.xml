<mujocoinclude>
    <!-- CRX-25iA 6-DOF robot on 0.4m pedestal at table end.
         Kinematics and masses from FK-validated URDF (serial 6064500003).
         Visual: green spheres at joints, white rectangular arm sections forming L-shape. -->

    <body name="fanuc/pedestal" pos="1.6 0 0">
        <inertial pos="0 0 0.3" mass="30" diaginertia="0.2 0.2 0.2"/>
        <geom name="fanuc_pedestal" type="box" size="0.2 0.2 0.3" pos="0 0 0.3"
              rgba="0.3 0.3 0.3 1" contype="1" conaffinity="1"/>

        <!-- Base: green cylinder (r=0.135, h=0.30) -->
        <body name="fanuc/base_link" pos="0 0 0.6">
            <inertial pos="0 0 0.10" mass="20" diaginertia="0.12 0.12 0.18"/>
            <geom name="fanuc_base" type="cylinder" size="0.135 0.15" pos="0 0 0.15"
                  rgba="0 0.55 0.25 1" contype="1" conaffinity="1"/>

            <!-- Link 1 / Shoulder: green sphere at J1/J2 joint complex -->
            <body name="fanuc/link_1" pos="0 0 0.405">
                <inertial pos="0 0 -0.05" mass="15" diaginertia="0.08 0.08 0.10"/>
                <joint name="fanuc/joint_1" range="-3.1416 3.1416" damping="20.0" axis="0 0 1" limited="true"/>
                <geom name="fanuc_shoulder" type="sphere" size="0.12"
                      rgba="0 0.55 0.25 1" contype="1" conaffinity="1"/>

                <!-- Link 2 / Upper arm: white rectangular box, 0.95m along Z (vertical) -->
                <body name="fanuc/link_2" pos="0 0 0">
                    <inertial pos="0 0 0.45" mass="30" diaginertia="2.5 2.5 0.15"/>
                    <joint name="fanuc/joint_2" range="-3.1416 3.1416" damping="20.0" axis="0 1 0" limited="true"/>
                    <geom name="fanuc_upper_arm" type="box" size="0.08 0.06 0.475" pos="0 0 0.475"
                          rgba="0.92 0.92 0.90 1" contype="1" conaffinity="1"/>

                    <!-- Link 3 / Elbow: green sphere at L-corner -->
                    <body name="fanuc/link_3" pos="0 -0.183 0.950">
                        <inertial pos="0 0 0" mass="10" diaginertia="0.06 0.06 0.06"/>
                        <joint name="fanuc/joint_3" range="-4.7124 4.7124" damping="10.0" axis="0 -1 0" limited="true"/>
                        <geom name="fanuc_elbow" type="sphere" size="0.12"
                              rgba="0 0.55 0.25 1" contype="1" conaffinity="1"/>

                        <!-- Link 4 / Forearm: white rectangular box, 0.73m along X (horizontal) -->
                        <body name="fanuc/link_4" pos="0 0 0">
                            <inertial pos="0.35 0 0" mass="8" diaginertia="0.03 0.40 0.40"/>
                            <joint name="fanuc/joint_4" range="-3.3161 3.3161" damping="5.0" axis="-1 0 0" limited="true"/>
                            <geom name="fanuc_forearm" type="box" size="0.365 0.06 0.05" pos="0.365 0 0"
                                  rgba="0.92 0.92 0.90 1" contype="1" conaffinity="1"/>

                            <!-- Link 5 / Wrist: green sphere -->
                            <body name="fanuc/link_5" pos="0.730 0 0">
                                <inertial pos="0 0 0" mass="3" diaginertia="0.01 0.01 0.01"/>
                                <joint name="fanuc/joint_5" range="-3.1416 3.1416" damping="2.0" axis="0 -1 0" limited="true"/>
                                <geom name="fanuc_wrist" type="sphere" size="0.08"
                                      rgba="0 0.55 0.25 1" contype="1" conaffinity="1"/>

                                <!-- Link 6 / Flange + EE: unchanged from here -->
                                <body name="fanuc/link_6" pos="0.140 0 0">
                                    <inertial pos="0.04 0 0" mass="2" diaginertia="0.002 0.002 0.002"/>
                                    <joint name="fanuc/joint_6" range="-3.3161 3.3161" damping="1.0" axis="-1 0 0" limited="true"/>
                                    <geom name="fanuc_flange" type="cylinder" size="0.045 0.05" pos="0.03 0 0"
                                          euler="0 1.5708 0" rgba="0.25 0.25 0.25 1" contype="1" conaffinity="1"/>
                                    <body name="EE" pos="0.0762 0 0" childclass="contact_geom">
                                        <site name="fanuc/tool_frame" pos="0 0 0" quat="0 0.70711 0 0.70711" rgba="0 1 1 0.5" size="0.01"/>
                                        <geom name="bat" type="cylinder" size="0.075 0.005" rgba="1 0 0 1"/>
                                        <geom name="bat_back" type="cylinder" size="0.074 0.003" rgba="0 1 0 1" pos="0 0 -0.003"/>
                                        <geom name="fanuc/paddle_handle" type="box" size="0.04 0.005 0.01" pos="-0.04 0 0" rgba="1 1 1 1"/>
                                        <site name="fanuc/paddle_center" pos="0 0 0" rgba="1 1 1 1" size="0.00001"/>
                                    </body>
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </body>
</mujocoinclude>
