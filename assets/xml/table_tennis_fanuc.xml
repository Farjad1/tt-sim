<mujoco model="table_tennis_fanuc(v0.1)">
    <compiler angle="radian" coordinate="local"/>
    <option gravity="0 0 -9.81" timestep="0.002">
        <flag warmstart="enable"/>
    </option>
    <custom>
        <numeric data="0 0 0 0 0 0" name="START_ANGLES"/>
    </custom>
    <default>
        <default class="viz">
            <geom type="mesh" contype="0" conaffinity="0" group="1" rgba="1 1 1 1"/>
        </default>
        <default class="col">
            <geom type="mesh" contype="0" conaffinity="1" group="0" rgba="1 1 1 1"/>
        </default>
        <default class="contact_geom">
            <geom condim="4" friction="0.1 0.1 0.1" margin="0" solimp="1 1 0" solref="0.1 0.03"/>
        </default>
    </default>
    <asset>
        <texture builtin="checker" height="512" name="texplane" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" type="2d" width="512"/>
        <material name="floor_plane" reflectance="0.5" texrepeat="1 1" texture="texplane" texuniform="true"/>
    </asset>
    <worldbody>
        <light cutoff="60" diffuse="1 1 1" dir="-.1 -.2 -1.3" directional="true" exponent="1" pos=".1 .2 1.3" specular=".1 .1 .1"/>
        <camera name="wide_table" pos="0 -4.0 3.0" xyaxes="1 0 0 0 0.6 0.8" fovy="60"/>
        <camera name="side_view" pos="-4.0 0 2.5" xyaxes="0 1 0 -0.5 0 0.866" fovy="60"/>
        <geom conaffinity="1" contype="1" material="floor_plane" name="floor" pos="0 0 0" size="10 5 1" type="plane"/>
        <include file="include_table.xml"/>
        <include file="include_fanuc_crx25ia.xml"/>
        <include file="include_target_ball.xml"/>
    </worldbody>
    <include file="include_fanuc_actuator.xml"/>

    <!-- Exclude self-collision between non-adjacent robot links -->
    <contact>
        <exclude body1="fanuc/pedestal" body2="fanuc/link_1"/>
        <exclude body1="fanuc/base_link" body2="fanuc/link_2"/>
        <exclude body1="fanuc/link_1" body2="fanuc/link_3"/>
        <exclude body1="fanuc/link_2" body2="fanuc/link_4"/>
        <exclude body1="fanuc/link_3" body2="fanuc/link_5"/>
        <exclude body1="fanuc/link_4" body2="fanuc/link_6"/>
        <exclude body1="fanuc/link_4" body2="EE"/>
        <exclude body1="fanuc/link_5" body2="EE"/>
    </contact>
</mujoco>
